# Atreus Backend Environment Variables

# Verifier Contract ID for ZK attestation (required)
NEXT_PUBLIC_VERIFIER_CONTRACT_ID=CA3WA53LKQEJH3L3FSLFOUBOB3DG7D4IHEE4GEMM35WC5Z5YWDN264DB

# Attester keypair secret key (required) — generate with: node -e "console.log(require('@stellar/stellar-sdk').Keypair.random().secret())"
# Must be funded on testnet and have authority to call VerifierContract.attest()
ATTESTER_SECRET_KEY=your-attester-secret-key

# Stellar network (optional, defaults to testnet)
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Server port (optional, defaults to 3001)
PORT=3001
