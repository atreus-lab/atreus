# Atreus Environment Variables

# Soroban Contract ID for Atreus escrow (required)
NEXT_PUBLIC_CONTRACT_ID=CAITLKEO4YJ5HQR6DORTWX5RAVD5XLSHCPWIOZIWSQF6CSNJIPXOQKT2

# Verifier Contract ID for ZK proof receipt service (required for claim flow)
NEXT_PUBLIC_VERIFIER_CONTRACT_ID=CA3WA53LKQEJH3L3FSLFOUBOB3DG7D4IHEE4GEMM35WC5Z5YWDN264DB

# Token Contract ID for native XLM (required, use native SAC address on testnet)
NEXT_PUBLIC_TOKEN_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Google OAuth Client ID (required for Sign in with Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Stellar RPC URL (optional, defaults to testnet)
# HORIZON_URL=https://horizon-testnet.stellar.org
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=your_secret

# Backend URL for ZK attestation-oracle service (required for claim flow)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
