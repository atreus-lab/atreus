# Atreus Environment Variables

# Soroban Contract ID (required)
NEXT_PUBLIC_CONTRACT_ID=

# Token Contract ID for XLM native asset (required)
NEXT_PUBLIC_TOKEN_ID=

# Stellar RPC URL (optional, defaults to testnet)
# HORIZON_URL=https://horizon-testnet.stellar.org
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Backend Port (optional, defaults to 3001)
# PORT=3001
