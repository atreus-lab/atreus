# Atreus Environment Variables

# Soroban Contract ID for Atreus escrow (required)
NEXT_PUBLIC_CONTRACT_ID=

# Verifier Contract ID for ZK proof receipt service (required for claim flow)
NEXT_PUBLIC_VERIFIER_CONTRACT_ID=

# Token Contract ID for native XLM (required, use native SAC address)
NEXT_PUBLIC_TOKEN_ID=

# Stellar RPC URL (optional, defaults to testnet)
# HORIZON_URL=https://horizon-testnet.stellar.org
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Backend Port (optional, defaults to 3001)
# PORT=3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=48137236127-ifd392aq57hvbn29ddvimhvbsepb2uua.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=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
# Secret key for the dedicated account that signs backend-created batch links.
BATCH_CREATOR_SECRET_KEY=
